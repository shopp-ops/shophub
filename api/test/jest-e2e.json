{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(@kubernetes|jsonpath-plus|@jsep-plugin|jsep|jose|oauth4webapi|openid-client|rfc4648)/)"
  ],
  "testTimeout": 60000
}
